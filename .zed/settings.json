{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },

  "languages": {
    "Rust": {
      "formatter": {
        "external": {
          "command": "rustfmt",
          "arguments": ["+nightly", "--edition", "2024"],
        },
      },
    },
  },
}
